# Claude API
ANTHROPIC_API_KEY=sk-ant-api-XXXXXXXXXXXXXXXXXXXX

# OBS WebSocket
OBS_HOST=localhost
OBS_PORT=4455
OBS_PASSWORD=MagicAI_Advisor_2026!
OBS_SOURCE_NAME=Game Capture 1903

# SQLite
DATABASE_PATH=./data/magic-ai.db

# Captura
CAPTURE_INTERVAL_MS=300
CAPTURE_WIDTH=1280
CAPTURE_HEIGHT=720

# IA
CLAUDE_MODEL_PRIMARY=claude-opus-4-8
CLAUDE_MODEL_FALLBACK=claude-haiku-4-5
CLAUDE_MAX_TOKENS_RECOMMENDATION=2500

# ATENCAO: os dois parametros abaixo NAO sao usados juntos.
# O codigo escolhe automaticamente (ver config.parametros_de_geracao).
#
#   Modelos 4.7+ (opus-4-8, opus-4-7, fable-5): usam CLAUDE_EFFORT.
#     Mandar temperature pra eles devolve erro 400.
#   Modelos anteriores (haiku-4-5, sonnet-4-6): usam CLAUDE_TEMPERATURE.
CLAUDE_TEMPERATURE=0.3
CLAUDE_EFFORT=high

# Idioma em que as cartas sao MOSTRADAS (ptBR ou enUS).
# Nao afeta a IA: pra ela vai sempre o nome em ingles.
IDIOMA_EXIBICAO=ptBR

# App
LOG_LEVEL=INFO
DEBUG_MODE=false
SAVE_SCREENSHOTS_DEBUG=false
